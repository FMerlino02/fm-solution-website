  "terms": {
    "title": "Terms of Service",
    "lastUpdated": "Last updated: February 10, 2026",
    "section1": {
      "title": "1. Acceptance of Terms",
      "content": "By using this site and FM Solution's services, you accept these terms of service. If you do not accept these terms, do not use our services."
    },
    "section2": {
      "title": "2. Services Offered",
      "content": "FM Solution offers software consulting, custom development, AI integration, and technical training services. Specific details of each service will be defined in separate contracts."
    },
    "section3": {
      "title": "3. Intellectual Property",
      "content": "The code, deliverables, and intellectual property developed for the client will be transferred to the client upon project completion and full payment, unless otherwise agreed contractually."
    },
    "section4": {
      "title": "4. Payments",
      "intro": "Payment terms will be specified in individual contracts. Generally:",
      "items": [
        "30% deposit at project start",
        "Interim payments tied to milestones",
        "Final balance upon delivery"
      ]
    },
    "section5": {
      "title": "5. Warranties and Liability",
      "content": "We guarantee that services will be provided with professional competence. However, we do not guarantee specific business results. Our liability is limited to the amount paid for the specific service."
    },
    "section6": {
      "title": "6. Confidentiality",
      "content": "We are committed to keeping all sensitive client information confidential. Separate NDAs can be signed if necessary."
    },
    "section7": {
      "title": "7. Contract Termination",
      "content": "Both parties may terminate the contract with 30 days written notice, unless otherwise specified contractually. Payments for work already performed remain due."
    },
    "section8": {
      "title": "8. Changes to Terms",
      "content": "We reserve the right to modify these terms. Changes will be communicated to active clients and posted on this page."
    },
    "section9": {
      "title": "9. Applicable Law",
      "content": "These terms are governed by Italian law. For disputes, the competent court is Milan."
    },
    "section10": {
      "title": "10. Contact",
      "intro": "For questions about the terms of service, contact us:",
      "email": "Email: info@fmsolution.it",
      "phone": "Tel: +39 012 345 6789"
    }
  }
